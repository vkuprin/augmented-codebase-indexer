# Copy this to .env and fill with your keys/endpoints.

# Embedding API (required)
# Supports OpenAI-compatible APIs (OpenAI, SiliconFlow, Azure, etc.)
ACI_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
ACI_EMBEDDING_API_KEY=your_embedding_api_key
ACI_EMBEDDING_MODEL=text-embedding-3-small
ACI_EMBEDDING_DIMENSION=1024
ACI_EMBEDDING_BATCH_SIZE=64
ACI_EMBEDDING_MAX_RETRIES=3
ACI_EMBEDDING_TIMEOUT=30

# Reranker API (optional)
# Set USE_RERANK to true and provide rerank API details if you want reranking.
ACI_SEARCH_USE_RERANK=false
ACI_SEARCH_RERANK_API_URL=https://api.example.com
ACI_SEARCH_RERANK_ENDPOINT=/v1/rerank
ACI_SEARCH_RERANK_API_KEY=your_rerank_api_key
ACI_SEARCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3
ACI_SEARCH_RERANK_TIMEOUT=30

# Vector store (Qdrant)
# If ACI_VECTOR_STORE_URL is set, it takes precedence over HOST/PORT.
# Cloud example:
# ACI_VECTOR_STORE_URL=https://xxxx.eu-central-1-0.aws.cloud.qdrant.io:6333
# ACI_VECTOR_STORE_API_KEY=your_qdrant_api_key
ACI_VECTOR_STORE_URL=
ACI_VECTOR_STORE_API_KEY=
ACI_VECTOR_STORE_HOST=localhost
ACI_VECTOR_STORE_PORT=6333
ACI_VECTOR_STORE_COLLECTION_NAME=aci_codebase
ACI_VECTOR_STORE_VECTOR_SIZE=1024

# Indexing
ACI_INDEXING_MAX_WORKERS=8
ACI_INDEXING_MAX_CHUNK_TOKENS=8192
ACI_INDEXING_CHUNK_OVERLAP_LINES=2
# Tokenizer strategy for chunk token counting.
# Use "character" or "simple" for Ollama/BERT-based models (e.g. nomic-embed-text,
# mxbai-embed-large) to avoid the tiktoken/WordPiece mismatch that causes
# "input length exceeds context length" errors.
#   tiktoken  - OpenAI BPE (default, accurate for OpenAI models)
#   character - len(text)/4 estimate (conservative, works with any model)
#   simple    - whitespace split (for generic non-BPE models)
ACI_TOKENIZER=tiktoken
# Optional comma-separated lists:
# ACI_INDEXING_FILE_EXTENSIONS=.py,.js,.ts,.go
# ACI_INDEXING_IGNORE_PATTERNS=__pycache__,*.pyc,.git,node_modules

# HTTP Server (for `aci serve`)
ACI_SERVER_HOST=0.0.0.0
ACI_SERVER_PORT=8000

# Environment (development/production)
# In development mode, debug logs are printed to stderr
ACI_ENV=development
